# Copy this file to .env and fill in real values from Firebase Console → Project Settings → Your apps
VITE_FIREBASE_API_KEY=YOUR_API_KEY
VITE_FIREBASE_AUTH_DOMAIN=YOUR_PROJECT_ID.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=YOUR_PROJECT_ID
VITE_FIREBASE_APP_ID=YOUR_APP_ID
VITE_API_BASE_URL=http://localhost:8081
VITE_USE_EMULATOR=true          # set to false in production
VITE_ALLOWED_EMAIL_DOMAINS=it-dc.cz,it-dc.sk
VITE_MSAL_CLIENT_ID=YOUR_AZURE_APP_CLIENT_ID
VITE_MSAL_TENANT_ID=YOUR_AZURE_TENANT_ID
