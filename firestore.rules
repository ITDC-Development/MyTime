rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function userProfile(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data;
    }

    function isAdmin() {
      return isAuthenticated() &&
             userProfile(request.auth.uid).role == 'admin' &&
             userProfile(request.auth.uid).status == 'active';
    }

    function isActiveUser() {
      return isAuthenticated() &&
             userProfile(request.auth.uid).status == 'active';
    }

    function isSelf(uid) {
      return request.auth.uid == uid;
    }

    function isAllowedDomain(email) {
      return email.matches('.*@(it-dc\\.cz|it-dc\\.sk)$');
    }

    function ownJiraAccount(accountId) {
      return userProfile(request.auth.uid).jiraAccountId == accountId;
    }

    // Pozvánky – admin vytváří (jen povolené domény), pozvaný uživatel může přečíst a označit jako použitou
    // Read je veřejný — token je crypto.randomUUID() (prakticky uhodnutelný), nepřihlášený uživatel
    // potřebuje ověřit pozvánku ještě před vytvořením účtu
    match /invites/{token} {
      allow read: if true;
      allow create: if isAdmin() && isAllowedDomain(request.resource.data.email);
      // Pouze příjemce pozvánky může změnit pole `used` na true
      allow update: if isAuthenticated() &&
                       request.auth.token.email == resource.data.email &&
                       request.resource.data.diff(resource.data).affectedKeys().hasOnly(['used']) &&
                       request.resource.data.used == true;
      allow delete: if isAdmin();
    }

    // Users collection
    match /users/{userId} {
      // Self-read; admin can read all
      allow read: if isSelf(userId) || isAdmin();
      // Vytvoření jen sobě, jen povolená doména, role musí být 'user', status musí být 'pending'
      allow create: if isSelf(userId) &&
                       isAllowedDomain(request.resource.data.email) &&
                       request.resource.data.role == 'user' &&
                       request.resource.data.status == 'pending';
      // Self-update of preferences only; admin can update role/status
      allow update: if
        (isSelf(userId) &&
         request.resource.data.diff(resource.data).affectedKeys()
           .hasOnly(['preferences', 'displayName'])) ||
        isAdmin();
      allow delete: if isAdmin();
    }

    // Worklogs (raw + edited + manual): only active users can read; admin writes all,
    // user can edit only own worklogs in unlocked months
    match /worklogs_raw/{worklogId} {
      allow read: if isAdmin() || (isActiveUser() && ownJiraAccount(resource.data.accountId));
      allow write: if isAdmin();
    }

    match /worklogs_edited/{worklogId} {
      allow read: if isAdmin() || (isActiveUser() && ownJiraAccount(resource.data.accountId));
      allow create: if isAdmin() || (isActiveUser() && ownJiraAccount(request.resource.data.accountId));
      allow update: if isAdmin() || (isActiveUser() && ownJiraAccount(resource.data.accountId));
      allow delete: if isAdmin() || (isActiveUser() && ownJiraAccount(resource.data.accountId));
    }

    match /manual_worklogs/{worklogId} {
      allow read: if isAdmin() || (isActiveUser() && ownJiraAccount(resource.data.accountId));
      allow create: if isAdmin() || (isActiveUser() && ownJiraAccount(request.resource.data.accountId));
      allow update: if isAdmin() || (isActiveUser() && ownJiraAccount(resource.data.accountId));
      allow delete: if isAdmin() || (isActiveUser() && ownJiraAccount(resource.data.accountId));
    }

    // Absences read-only for active users; backend writes
    match /absences/{absenceId} {
      allow read: if isAdmin() || (isActiveUser() && ownJiraAccount(resource.data.accountId));
      allow write: if isAdmin();
    }

    // Locks: read own or admin
    match /locks/{lockId} {
      allow read: if isAdmin() || (isActiveUser() && ownJiraAccount(resource.data.accountId));
      allow write: if isAdmin();
    }

    // Audit log: read own or admin, write own or admin
    match /audit_log/{logId} {
      allow read: if isAdmin() || (isActiveUser() && ownJiraAccount(resource.data.accountId));
      allow create: if isAdmin() || (isActiveUser() && ownJiraAccount(request.resource.data.accountId));
    }

    // Sync log: admin only
    match /sync_log/{logId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // Members (AT directory): readable by all active users, writable only by backend
    match /members/{memberId} {
      allow read: if isActiveUser();
      allow write: if isAdmin();
    }

    // Tag definitions: readable by active users, writable by admin
    match /tag_definitions/{tagId} {
      allow read: if isActiveUser();
      allow write: if isAdmin();
    }

    // Sync settings: admin only
    match /sync_settings/{settingId} {
      allow read: if isActiveUser();
      allow write: if isAdmin();
    }
  }
}
